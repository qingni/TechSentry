# OpenAI API Key (使用 OpenAI 官方模型时需要)
OPENAI_API_KEY=your-openai-api-key

# GitHub API Token (必须)
GITHUB_TOKEN=your-github-token

# Gmail 应用专用密码 (邮件通知需要)
GMAIL_SPECIAL_PASSWORD=your-gmail-app-password

# LLM API Token (必须)
LLM_API_TOKEN=your-llm-api-token

# LLM API Base URL (必须)
LLM_BASE_URL=http://dev.fit-ai.woa.com/api/llmproxy

# 邮件通知配置
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com

# 企业微信机器人 Webhook URL
WX_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key
